ETL_IDENTITY_CONFIG_DIR=.
ETL_IDENTITY_STATE_DB=postgresql+psycopg://etl_identity:change_me@postgres.internal:5432/identity_state
ETL_IDENTITY_OBJECT_STORAGE_ACCESS_KEY_FILE=/runtime/secrets/object-storage-access-key.txt
ETL_IDENTITY_OBJECT_STORAGE_SECRET_KEY_FILE=/runtime/secrets/object-storage-secret-key.txt
ETL_IDENTITY_SERVICE_JWT_ISSUER=https://issuer.example.gov
ETL_IDENTITY_SERVICE_JWT_AUDIENCE=etl-identity-api
ETL_IDENTITY_SERVICE_JWT_PUBLIC_KEY_PEM_FILE=/runtime/secrets/jwt-public-key.pem
ETL_IDENTITY_TLS_CERT_PATH=/runtime/tls/tls.crt
ETL_IDENTITY_TLS_KEY_PATH=/runtime/tls/tls.key
ETL_IDENTITY_AUDIT_LOG_DIR=/runtime/audit
ETL_IDENTITY_BACKUP_ROOT=/runtime/backups
ETL_IDENTITY_RUNTIME_AUTH_MAX_AGE_HOURS=720
ETL_IDENTITY_CJIS_ENCRYPTION_AT_REST=1
ETL_IDENTITY_CJIS_MFA_ENFORCED=1
ETL_IDENTITY_CJIS_PERSONNEL_SCREENING=1
ETL_IDENTITY_CJIS_SECURITY_ADDENDUM=1
ETL_IDENTITY_CJIS_AUDIT_REVIEW=1
ETL_IDENTITY_CJIS_INCIDENT_CONTACT=security@example.gov
